<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            style="-fx-background-color: #FFF5F7;">

    <children>

        <StackPane AnchorPane.topAnchor="0.0"
                   AnchorPane.bottomAnchor="0.0"
                   AnchorPane.leftAnchor="0.0"
                   AnchorPane.rightAnchor="0.0">

            <children>

                <HBox maxWidth="900"
                      maxHeight="600"
                      prefWidth="900"
                      prefHeight="600">

                    <!-- LEFT SIDE -->

                    <VBox prefWidth="400"
                          alignment="CENTER"
                          spacing="20"
                          style="-fx-background-color: linear-gradient(to bottom, #F8D7E3, #FCEEF5);">

                        <children>

                            <Label text="💅"
                                   style="-fx-font-size: 60px;" />

                            <Label text="GLAMMY"
                                   style="-fx-font-size: 38px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #D86F9B;" />

                            <Label text="Glow Beyond Beauty"
                                   style="-fx-font-size: 18px;
                                          -fx-text-fill: #8A6F7B;" />

                            <Label text="Book your beauty appointments easily and elegantly."
                                   wrapText="true"
                                   maxWidth="250"
                                   style="-fx-font-size: 14px;
                                          -fx-text-fill: #8A6F7B;
                                          -fx-alignment: center;" />

                        </children>

                    </VBox>

                    <!-- RIGHT SIDE -->

                    <VBox prefWidth="500"
                          alignment="CENTER"
                          spacing="18"
                          style="-fx-background-color: white;">

                        <children>

                            <Label text="Welcome Back 💇"
                                   style="-fx-font-size: 40px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #D86F9B;" />

                            <TextField promptText="Enter your email"
                                       prefWidth="280"
                                       prefHeight="45"
                                       style="-fx-background-radius: 15;
                                              -fx-font-size: 14px;
                                              -fx-padding: 10;" />

                            <PasswordField promptText="Enter your password"
                                           prefWidth="280"
                                           prefHeight="45"
                                           style="-fx-background-radius: 15;
                                                  -fx-font-size: 14px;
                                                  -fx-padding: 10;" />

                            <Button text="Login"
                                    prefWidth="280"
                                    prefHeight="45"
                                    style="-fx-background-color: #E8A0BF;
                                           -fx-text-fill: white;
                                           -fx-font-size: 15px;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 15;" />

                            <Button text="Register"
                                    prefWidth="280"
                                    prefHeight="45"
                                    style="-fx-background-color: white;
                                           -fx-text-fill: #D86F9B;
                                           -fx-font-size: 15px;
                                           -fx-font-weight: bold;
                                           -fx-border-color: #E8A0BF;
                                           -fx-border-radius: 15;
                                           -fx-background-radius: 15;" />

                        </children>

                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20"/>
                        </padding>

                    </VBox>

                </HBox>

            </children>

        </StackPane>

    </children>

</AnchorPane>
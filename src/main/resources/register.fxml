<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<AnchorPane
        fx:controller="com.example.glammy.controller.RegisterController"
        prefHeight="950.0"
        prefWidth="1600.0"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        style="-fx-background-color: linear-gradient(to bottom right, #FFF7FB, #FFE8F1, #FFD8E8);">

    <children>

        <!-- BACKGROUND CIRCLES -->

        <Circle centerX="180"
                centerY="120"
                radius="140"
                fill="#FFD6E7"
                opacity="0.35"/>

        <Circle centerX="1450"
                centerY="180"
                radius="180"
                fill="#FFC9DD"
                opacity="0.25"/>

        <Circle centerX="250"
                centerY="820"
                radius="130"
                fill="#FFE4EF"
                opacity="0.28"/>

        <Circle centerX="1380"
                centerY="760"
                radius="170"
                fill="#FFD6E7"
                opacity="0.22"/>

        <!-- DECOR -->

        <Label layoutX="120"
               layoutY="220"
               text="✨"
               style="-fx-font-size: 65px;
                      -fx-opacity: 0.20;" />

        <Label layoutX="1360"
               layoutY="260"
               text="💄"
               style="-fx-font-size: 70px;
                      -fx-opacity: 0.18;" />

        <Label layoutX="180"
               layoutY="690"
               text="🎀"
               style="-fx-font-size: 60px;
                      -fx-opacity: 0.18;" />

        <Label layoutX="1320"
               layoutY="650"
               text="🌸"
               style="-fx-font-size: 65px;
                      -fx-opacity: 0.18;" />

        <!-- MAIN CARD -->

        <StackPane AnchorPane.topAnchor="0.0"
                   AnchorPane.bottomAnchor="0.0"
                   AnchorPane.leftAnchor="0.0"
                   AnchorPane.rightAnchor="0.0">

            <VBox spacing="24"
                  alignment="CENTER"
                  maxWidth="560"
                  style="-fx-background-color: rgba(255,255,255,0.92);
                         -fx-background-radius: 50;
                         -fx-border-radius: 50;
                         -fx-border-color: #FFD6E7;
                         -fx-border-width: 2;">

                <effect>
                    <DropShadow radius="25"
                                spread="0.03"
                                offsetY="6"
                                color="#EBC0D1"/>
                </effect>

                <padding>
                    <Insets top="55"
                            right="50"
                            bottom="50"
                            left="50"/>
                </padding>

                <!-- TITLE -->

                <VBox alignment="CENTER"
                      spacing="10">

                    <Label text="Create Account ✨"
                           style="-fx-font-size: 40px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #D95D92;" />

                    <Label text="Become part of Glammy Beauty Studio"
                           style="-fx-font-size: 16px;
                                  -fx-text-fill: #B57C94;" />

                </VBox>

                <!-- INPUTS -->

                <VBox spacing="18"
                      alignment="CENTER">

                    <!-- FULL NAME -->

                    <TextField fx:id="nameField"
                               promptText="Full Name"
                               prefWidth="390"
                               prefHeight="58"
                               style="-fx-background-color: white;
                                      -fx-background-radius: 28;
                                      -fx-border-radius: 28;
                                      -fx-border-color: #FFD6E7;
                                      -fx-border-width: 1.5;
                                      -fx-font-size: 15px;
                                      -fx-padding: 0 0 0 22;" />

                    <!-- EMAIL -->

                    <TextField fx:id="emailField"
                               promptText="Email Address"
                               prefWidth="390"
                               prefHeight="58"
                               style="-fx-background-color: white;
                                      -fx-background-radius: 28;
                                      -fx-border-radius: 28;
                                      -fx-border-color: #FFD6E7;
                                      -fx-border-width: 1.5;
                                      -fx-font-size: 15px;
                                      -fx-padding: 0 0 0 22;" />

                    <!-- PHONE -->

                    <TextField promptText="Phone Number"
                               prefWidth="390"
                               prefHeight="58"
                               style="-fx-background-color: white;
                                      -fx-background-radius: 28;
                                      -fx-border-radius: 28;
                                      -fx-border-color: #FFD6E7;
                                      -fx-border-width: 1.5;
                                      -fx-font-size: 15px;
                                      -fx-padding: 0 0 0 22;" />

                    <!-- PASSWORD -->

                    <PasswordField fx:id="passwordField"
                                   promptText="Password"
                                   prefWidth="390"
                                   prefHeight="58"
                                   style="-fx-background-color: white;
                                          -fx-background-radius: 28;
                                          -fx-border-radius: 28;
                                          -fx-border-color: #FFD6E7;
                                          -fx-border-width: 1.5;
                                          -fx-font-size: 15px;
                                          -fx-padding: 0 0 0 22;" />

                    <!-- CONFIRM PASSWORD -->

                    <PasswordField fx:id="confirmPasswordField"
                                   promptText="Confirm Password"
                                   prefWidth="390"
                                   prefHeight="58"
                                   style="-fx-background-color: white;
                                          -fx-background-radius: 28;
                                          -fx-border-radius: 28;
                                          -fx-border-color: #FFD6E7;
                                          -fx-border-width: 1.5;
                                          -fx-font-size: 15px;
                                          -fx-padding: 0 0 0 22;" />

                </VBox>

                <!-- CREATE ACCOUNT BUTTON -->

                <Button text="Create Account"
                        onAction="#goToHome"
                        prefWidth="350"
                        prefHeight="60"
                        style="-fx-background-color: linear-gradient(to right, #FF8FB6, #FFBFD3);
                               -fx-text-fill: white;
                               -fx-font-size: 17px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 32;
                               -fx-cursor: hand;" />

                <!-- LOGIN -->

                <HBox alignment="CENTER"
                      spacing="6">

                    <Label text="Already have an account?"
                           style="-fx-font-size: 14px;
                                  -fx-text-fill: #B57C94;" />

                    <Hyperlink text="Login"
                               onAction="#goToLogin"
                               style="-fx-text-fill: #D86F9B;
                                      -fx-font-size: 14px;
                                      -fx-font-weight: bold;
                                      -fx-border-color: transparent;" />

                </HBox>

            </VBox>

        </StackPane>

    </children>

</AnchorPane>